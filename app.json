{
  "expo": {
    "name": "DawaMZ",
    "slug": "dawamz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/logo.png",
    "scheme": "dawamz",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2196F3",
        "foregroundImage": "./assets/images/logo/logo.png",
        "monochromeImage": "./assets/images/logo/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.dawamzsorganization.dawamz"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/loading_logo.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#2196F3",
          "hideExpoText": true
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6df4a20d-a0eb-4830-9f15-de0cb3b556be"
      }
    },
    "owner": "dawamzs-organization"
  }
}
